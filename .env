DATABASE_PROVIDER=mysql
DATABASE_CONNECTION_URI='mysql://user_name:user_password@db:3306/my_app_db'# Client name for the database connection

# Redis (Internal)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI='redis://evolution_redis:6379/6'

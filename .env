# Enable the use of the database
DATABASE_ENABLED=true

# Choose the database provider: postgresql or mysql
# DATABASE_PROVIDER=postgresql
DATABASE_PROVIDER=mysql

# Database connection URI
# DATABASE_CONNECTION_URI='mysql://user:pass@localhost:5432/evolution?schema=public'
# Database connection URI 
# Note: Host is 'db' (the service name), port is 3306 (internal Docker port)
DATABASE_CONNECTION_URI='mysql://user_name:user_password@db:3306/my_app_db'# Client name for the database connection
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

# Choose the data you want to save in the application database
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true



# Enable Redis cache
CACHE_REDIS_ENABLED=true

# Redis connection URI
# Use the service name 'redis' instead of localhost
CACHE_REDIS_URI='redis://redis:6379/6'

# Prefix to differentiate data from different installations using the same Redis
CACHE_REDIS_PREFIX_KEY=evolution

# Enable to save connection information in Redis instead of the database
CACHE_REDIS_SAVE_INSTANCES=false

# Enable local cache
CACHE_LOCAL_ENABLED=false
AUTHENTICATION_API_KEY=change-me


# Evolution API Settings
AUTHENTICATION_API_KEY=your_secret_key
EVO_INSTANCE=MainInstance
EVO_URL=http://nginx_server # Internal Docker networking

# Database Settings (Pointing to Aiven)
